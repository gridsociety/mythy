<?xml version="1.0" encoding="UTF-8"?>
<DEVICE NAME="TEST_V00" IDENTIFICATION="99999" PROTOCOLRELEASE="0100" XMLRELEASE="0101" FAMILY="TEST">
  <PRIVATE>
    <ITEM NAME="Identification" MESSAGE="IDENTIFICATION"/>
  </PRIVATE>
  <MODULES>
    <MODULE name="SchedaMadre" variabile="EnableBoard_Madre" dsc="Mainboard"/>
    <MODULE name="SchedaMMI" variabile="EnableBoard_MMI" dsc="MMI module"/>
  </MODULES>
  <WSDL>
    <definitions name="TEST_E00">
      <types><schema/></types>

      <message name="IDENTIFICATION" type="RREG" num="5183" dim="5"/>
      <message name="IDENTIFICATIONResponse">
        <part name="Identification"   type="WORD"/>
        <part name="SerialNumber"     type="LONG"/>
        <part name="FwRelease"        type="WORD"/>
        <part name="ProtocolRelease" type="WORD"/>
      </message>

      <message name="START_CHANGE_DB" type="RREG" num="5123" dim="1"/>
      <message name="END_CHANGE_DB"   type="RREG" num="5124" dim="1"/>
      <message name="RESET_CHANGE_DB" type="RREG" num="5165" dim="1"/>
      <message name="MSG_CMD_RESET_DA_PC" type="RREG" num="5201" dim="1"/>
      <message name="MSG_GST61850"   type="RREG" num="5148" dim="1"/>
      <message name="SET_RTC" type="WREG" num="5169" dim="6">
        <part name="RTCDay"    type="UWORD"/>
        <part name="RTCMonth"  type="UWORD"/>
        <part name="RTCYear"   type="UWORD"/>
        <part name="RTCHour"   type="UWORD"/>
        <part name="RTCMinute" type="UWORD"/>
        <part name="RTCSecond" type="UWORD"/>
      </message>
      <message name="SET_RTCResponse"/>

      <message level="BY_USER_LEVEL_2" dsc="Address" name="MB_address"
               CLASS="UBYTE_PARAM" type="WREG" num="6146" dim="1"/>
      <message name="MB_addressResponse"/>

      <message level="BY_USER_LEVEL_2" dsc="IP test address" name="TEST_IP_Address"
               CLASS="UBYTE_PARAM" type="WREG" num="6147" dim="1"/>
      <message name="TEST_IP_AddressResponse"/>

      <message level="BY_USER_LEVEL_1" dsc="Module enable test" name="TEST_EnableBoard"
               CLASS="UBYTE_PARAM" type="WREG" num="6148" dim="1"/>
      <message name="TEST_EnableBoardResponse"/>

      <message level="BY_USER_LEVEL_2" dsc="Compound with TIPO override" name="TEST_SOGLIA"
               CLASS="SOGLIA_T" type="WREG" num="6149" dim="3"/>
      <message name="TEST_SOGLIAResponse"/>

      <message level="BY_USER_LEVEL_2" dsc="PT100-board setting" name="TEST_PT100_Setting"
               CLASS="UBYTE_PARAM" type="WREG" num="6150" dim="1"/>
      <message name="TEST_PT100_SettingResponse"/>

      <message level="BY_USER_LEVEL_1" dsc="Reference name" name="NomeLinea"
               CLASS="STRING_PARAM" type="WREG" num="6200" dim="10"/>
      <message name="NomeLineaResponse"/>

      <message level="NO_CHANGEABLE" dsc="Voltage L1" name="UL1"
               CLASS="ULONG_RAM" type="RREG" num="40000" dim="2"/>
      <message name="UL1Response"/>

      <message level="BY_USER_LEVEL_2" dsc="Synchro counter" name="F25_CONT_P_Sc"
               CLASS="CONTATORE" type="RREG" num="40010" dim="3"/>
      <message name="F25_CONT_P_ScResponse"/>

      <message level="BY_USER_LEVEL_2" dsc="Frequency enable delay" name="EnF81_TSc"
               CLASS="TIMER" type="WREG" num="40020" dim="4"/>
      <message name="EnF81_TScResponse"/>

      <message level="BY_USER_LEVEL_2" dsc="Baudrate RS485" name="MB_baudrate"
               CLASS="ENUM_PARAM" type="WREG" num="15363" dim="1"/>
      <message name="MB_baudrateResponse"/>

      <message level="BY_USER_LEVEL_2" dsc="Enable Secure mode" name="ENABLE_SEC_MODE"
               CLASS="ENUM_RAM" type="RREG" num="54295" dim="1"/>
      <message name="ENABLE_SEC_MODEResponse"/>

      <message level="BY_USER_LEVEL_1" dsc="61850 cmd" name="GST61850_CMD"
               CLASS="ENUM_RAM" type="RREG" num="54587" dim="1"/>
      <message name="GST61850_CMDResponse"/>
      <message level="BY_USER_LEVEL_1" dsc="61850 par1" name="GST61850_CMD_PAR1"
               CLASS="STRING_RAM" type="RREG" num="51258" dim="50"/>
      <message name="GST61850_CMD_PAR1Response"/>
      <message level="BY_USER_LEVEL_1" dsc="61850 par2" name="GST61850_CMD_PAR2"
               CLASS="STRING_RAM" type="RREG" num="51259" dim="50"/>
      <message name="GST61850_CMD_PAR2Response"/>
      <message level="BY_USER_LEVEL_1" dsc="61850 reply" name="GST61850_CMD_REPLY"
               CLASS="STRING_RAM" type="RREG" num="51257" dim="50"/>
      <message name="GST61850_CMD_REPLYResponse"/>

      <ENUM name="ON_OFF">
        <RANGE VALUE="OFF" OVERRIDE="0"/>
        <RANGE VALUE="ON"  OVERRIDE="1"/>
      </ENUM>
      <ENUM name="EnumBaudrate">
        <RANGE VALUE="1200 baud"  OVERRIDE="0"/>
        <RANGE VALUE="9600 baud"  OVERRIDE="3"/>
        <RANGE VALUE="19200 baud" OVERRIDE="4"/>
      </ENUM>
      <ENUM name="Gst61850_Msg">
        <RANGE VALUE="WriteCid"          OVERRIDE="0"/>
        <RANGE VALUE="ResetCid"          OVERRIDE="1"/>
        <RANGE VALUE="ResetAll"          OVERRIDE="2"/>
        <RANGE VALUE="RestartDevice"     OVERRIDE="3"/>
        <RANGE VALUE="GetIcdName"        OVERRIDE="4"/>
        <RANGE VALUE="GetCidName"        OVERRIDE="5"/>
        <RANGE VALUE="GetAccessPointName" OVERRIDE="6"/>
        <RANGE VALUE="GetIedName"        OVERRIDE="7"/>
        <RANGE VALUE="SetIedName"        OVERRIDE="8"/>
        <RANGE VALUE="GetReportScanRate" OVERRIDE="9"/>
        <RANGE VALUE="SetReportScanRate" OVERRIDE="10"/>
        <RANGE VALUE="GetBrcbBufSize"    OVERRIDE="11"/>
        <RANGE VALUE="SetBrcbBufSize"    OVERRIDE="12"/>
      </ENUM>

      <CLASS NAME="CONTATORE" DIM="3">
        <VAR NAME="Tipo"      TIPO="ENUM_LONG"/>
        <VAR NAME="MaxValore" TIPO="UWORD"/>
      </CLASS>
      <CLASS NAME="TIMER" DIM="4">
        <VAR NAME="Valore"     TIPO="ULONG"/>
        <VAR NAME="Correzione" TIPO="LONG"/>
      </CLASS>
      <!-- CLASS dichiara State come ENUM (1 reg); le istanze fanno
           override a ENUM_LONG (2 reg) via nested <DATA>. DIM=3 =
           2 (State, overridden) + 1 (Pickup). Riproduzione minimale
           di SOGLIA in NV10P-EB0-u, per testare issue #6. -->
      <CLASS NAME="SOGLIA_T" DIM="3">
        <VAR NAME="State"  TIPO="ENUM">
          <RANGE VALUE="OFF" OVERRIDE="0"/>
          <RANGE VALUE="ON"  OVERRIDE="1"/>
        </VAR>
        <VAR NAME="Pickup" TIPO="UWORD"/>
      </CLASS>
    </definitions>
  </WSDL>
  <MENU>
    <GROUP NAME="Read">
      <GROUP NAME="Measures" REFRESH="YES">
        <DATA NAME="UL1" DSC="Voltage L1" TIPO="ULONG" READONLY="YES" VALORE=""/>
      </GROUP>
      <GROUP NAME="Counters">
        <DATA NAME="F25_CONT_P_Sc" DSC="Synchro counter" TIPO="CONTATORE" READONLY="YES" VALORE=""/>
      </GROUP>
      <GROUP NAME="Info">
        <DATA NAME="ENABLE_SEC_MODE" DSC="Enable Secure mode" TIPO="ENUM" ENUM="ON_OFF" VALORE="0" DEFAULT="0" READONLY="YES"/>
      </GROUP>
    </GROUP>
    <GROUP NAME="Set">
      <GROUP NAME="Base">
        <DATA NAME="NomeLinea" DSC="Reference name" TIPO="STRING" VALORE="......" DEFAULT="......" READONLY="YES"/>
        <DATA NAME="MB_address" DSC="Modbus address" TIPO="UBYTE" VALORE="1" DEFAULT="1" VISIBILITY="1"/>
      </GROUP>
      <GROUP NAME="Timers">
        <DATA NAME="EnF81_TSc" DSC="Frequency enable delay" TIPO="TIMER" VALORE=""/>
      </GROUP>
      <GROUP NAME="Soglie">
        <DATA NAME="TEST_SOGLIA" DSC="Test compound with TIPO override" TIPO="SOGLIA_T" VALORE="">
          <DATA NAME="State"  TIPO="ENUM_LONG" DEFAULT="0" VALORE="0"/>
          <DATA NAME="Pickup" TIPO="UWORD"     DEFAULT="0" VALORE="0"/>
        </DATA>
      </GROUP>
      <GROUP NAME="PT100">
        <DATA NAME="TEST_PT100_Setting" DSC="PT100-board setting" TIPO="UBYTE" VALORE="0" DEFAULT="0" MODULE="SchedaPT100"/>
      </GROUP>
    </GROUP>
    <GROUP NAME="Communication">
      <GROUP NAME="RS485">
        <DATA NAME="MB_baudrate" DSC="Baudrate RS485" TIPO="ENUM" ENUM="EnumBaudrate" VALORE="3" DEFAULT="3"/>
      </GROUP>
      <GROUP NAME="Ethernet">
        <DATA NAME="TEST_IP_Address" DSC="IP test address" TIPO="UBYTE" SKIP="YES" VALORE="1" DEFAULT="1"/>
      </GROUP>
    </GROUP>
    <GROUP NAME="Administrator" VISIBILITY="3">
      <GROUP NAME="Identification" VISIBILITY="3">
        <DATA NAME="Identification" DSC="Identifier number" TIPO="WORD" VALORE="99999" DEFAULT="99999" READONLY="YES"/>
      </GROUP>
      <GROUP NAME="Modules assigned" VISIBILITY="3">
        <DATA NAME="TEST_EnableBoard" DSC="Module enable test" TIPO="UBYTE" VALORE="1" DEFAULT="1"/>
      </GROUP>
      <GROUP NAME="Parser 61850" VISIBILITY="3">
        <COMMAND NAME="MSG_GST61850" DSC="61850 Support" VISIBILITY="1"/>
        <DATA NAME="GST61850_CMD"      DSC="61850 cmd"   TIPO="ENUM" ENUM="Gst61850_Msg" VALORE="7" DEFAULT="7" VISIBILITY="1"/>
        <DATA NAME="GST61850_CMD_PAR1" DSC="61850 par1"  TIPO="STRING" VALORE="" VISIBILITY="1"><RANGE VALUE="100"/></DATA>
        <DATA NAME="GST61850_CMD_PAR2" DSC="61850 par2"  TIPO="STRING" VALORE="" VISIBILITY="1"><RANGE VALUE="100"/></DATA>
        <DATA NAME="GST61850_CMD_REPLY" DSC="61850 reply" TIPO="STRING" VALORE="" VISIBILITY="1"><RANGE VALUE="100"/></DATA>
      </GROUP>
    </GROUP>
    <GROUP NAME="Commands">
      <COMMAND NAME="MSG_CMD_RESET_DA_PC" DSC="Reset"/>
      <COMMAND NAME="SET_RTC" DSC="Set RTC"/>
    </GROUP>
  </MENU>
</DEVICE>
